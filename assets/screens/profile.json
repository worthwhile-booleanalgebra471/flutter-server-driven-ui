{
  "schemaVersion": "1.0",
  "context": {
    "user": { "name": "Ryanditko" }
  },
  "screen": {
    "id": "profile",
    "title": "Profile",
    "root": {
      "type": "column",
      "props": {
        "mainAxisAlignment": "start",
        "crossAxisAlignment": "stretch",
        "padding": { "top": 32, "bottom": 32, "left": 24, "right": 24 }
      },
      "children": [
        {
          "type": "center",
          "children": [
            {
              "type": "container",
              "props": {
                "padding": 4,
                "decoration": {
                  "gradient": {
                    "type": "linear",
                    "colors": ["#820AD1", "#D72F87"],
                    "begin": "topLeft",
                    "end": "bottomRight"
                  },
                  "borderRadius": 64
                }
              },
              "children": [
                {
                  "type": "container",
                  "props": {
                    "padding": 3,
                    "decoration": {
                      "color": "#FFFFFF",
                      "borderRadius": 60
                    }
                  },
                  "children": [
                    {
                      "type": "image",
                      "props": {
                        "url": "https://avatars.githubusercontent.com/u/196965460?v=4",
                        "width": 112,
                        "height": 112,
                        "borderRadius": 56
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        { "type": "spacer", "props": { "height": 16 } },
        {
          "type": "text",
          "props": {
            "content": "{{user.name}}",
            "style": { "fontSize": 26, "fontWeight": "bold", "textAlign": "center" }
          }
        },
        { "type": "spacer", "props": { "height": 4 } },
        {
          "type": "center",
          "children": [
            {
              "type": "chip",
              "props": { "label": "Flutter Developer", "backgroundColor": "#820AD1", "textColor": "#FFFFFF" }
            }
          ]
        },
        { "type": "spacer", "props": { "height": 24 } },

        {
          "type": "row",
          "props": { "mainAxisAlignment": "spaceEvenly" },
          "children": [
            {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "props": { "content": "103", "style": { "fontSize": 22, "fontWeight": "bold", "color": "#820AD1", "textAlign": "center" } }
                },
                {
                  "type": "text",
                  "props": { "content": "Components", "style": { "fontSize": 12, "color": "#888888", "textAlign": "center" } }
                }
              ]
            },
            {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "props": { "content": "8", "style": { "fontSize": 22, "fontWeight": "bold", "color": "#D72F87", "textAlign": "center" } }
                },
                {
                  "type": "text",
                  "props": { "content": "Screens", "style": { "fontSize": 12, "color": "#888888", "textAlign": "center" } }
                }
              ]
            },
            {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "props": { "content": "7", "style": { "fontSize": 22, "fontWeight": "bold", "color": "#00897B", "textAlign": "center" } }
                },
                {
                  "type": "text",
                  "props": { "content": "Actions", "style": { "fontSize": 12, "color": "#888888", "textAlign": "center" } }
                }
              ]
            }
          ]
        },

        { "type": "spacer", "props": { "height": 24 } },

        {
          "type": "card",
          "props": { "padding": 0, "elevation": 0 },
          "children": [
            {
              "type": "column",
              "children": [
                {
                  "type": "listTile",
                  "props": {
                    "title": "GitHub",
                    "subtitle": "github.com/Ryanditko",
                    "leadingIcon": "code"
                  },
                  "action": { "type": "openUrl", "message": "https://github.com/Ryanditko" }
                },
                { "type": "divider", "props": { "height": 1, "indent": 56 } },
                {
                  "type": "listTile",
                  "props": {
                    "title": "Repository",
                    "subtitle": "flutter-server-driven-ui",
                    "leadingIcon": "folder_open"
                  },
                  "action": { "type": "openUrl", "message": "https://github.com/Ryanditko/flutter-server-driven-ui" }
                },
                { "type": "divider", "props": { "height": 1, "indent": 56 } },
                {
                  "type": "listTile",
                  "props": {
                    "title": "Copy Profile Link",
                    "subtitle": "Share your profile",
                    "leadingIcon": "share"
                  },
                  "action": { "type": "copyToClipboard", "message": "https://github.com/Ryanditko" }
                }
              ]
            }
          ]
        },

        { "type": "spacer", "props": { "height": 24 } },
        {
          "type": "button",
          "props": {
            "label": "Back to Home",
            "style": { "backgroundColor": "#820AD1", "textColor": "#FFFFFF" }
          },
          "action": { "type": "navigate", "targetScreenId": "home" }
        }
      ]
    }
  }
}

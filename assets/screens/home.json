{
  "schemaVersion": "1.0",
  "screen": {
    "id": "home",
    "title": "Home",
    "root": {
      "type": "column",
      "props": {
        "mainAxisAlignment": "start",
        "crossAxisAlignment": "stretch",
        "padding": { "top": 32, "bottom": 32, "left": 24, "right": 24 }
      },
      "children": [
        {
          "type": "text",
          "props": {
            "content": "Welcome to Server-Driven UI",
            "style": { "fontSize": 28, "fontWeight": "bold", "textAlign": "center" }
          }
        },
        { "type": "spacer", "props": { "height": 12 } },
        {
          "type": "text",
          "props": {
            "content": "This screen is rendered entirely from a JSON contract. No hardcoded layouts — the widget tree is built dynamically at runtime.",
            "style": { "fontSize": 16, "color": "#666666" }
          }
        },
        { "type": "spacer", "props": { "height": 32 } },
        {
          "type": "card",
          "props": {
            "padding": { "top": 16, "bottom": 16, "left": 16, "right": 16 },
            "elevation": 2
          },
          "children": [
            {
              "type": "column",
              "props": { "crossAxisAlignment": "start" },
              "children": [
                {
                  "type": "text",
                  "props": {
                    "content": "Quick Actions",
                    "style": { "fontSize": 18, "fontWeight": "w600" }
                  }
                },
                { "type": "spacer", "props": { "height": 12 } },
                {
                  "type": "button",
                  "props": {
                    "label": "View Profile",
                    "style": { "backgroundColor": "#6200EE", "textColor": "#FFFFFF" }
                  },
                  "action": { "type": "navigate", "targetScreenId": "profile" }
                },
                { "type": "spacer", "props": { "height": 8 } },
                {
                  "type": "button",
                  "props": {
                    "label": "Open Form Demo",
                    "style": { "backgroundColor": "#03DAC5", "textColor": "#000000" }
                  },
                  "action": { "type": "navigate", "targetScreenId": "form" }
                }
              ]
            }
          ]
        },
        { "type": "spacer", "props": { "height": 24 } },
        {
          "type": "image",
          "props": {
            "url": "https://picsum.photos/seed/bdc/600/200",
            "height": 200,
            "fit": "cover",
            "borderRadius": 12
          }
        }
      ]
    }
  }
}
